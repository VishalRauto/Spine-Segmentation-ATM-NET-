# ATM-Net++ Environment Variables
# Copy to .env and fill in values

# ── App ──────────────────────────────────────────────────────────────
APP_NAME="ATM-Net++ API"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# ── Security (CHANGE THESE!) ─────────────────────────────────────────
SECRET_KEY=your-super-secret-key-min-32-chars-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://atmnet:atmnet_pass@db:5432/atmnet_db

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Model ─────────────────────────────────────────────────────────────
MODEL_CHECKPOINT_PATH=checkpoints/atmnet_pp_best.pth
MODEL_CONFIG_PATH=configs/base_config.yaml
MODEL_DEVICE=auto
USE_TTA=false

# ── Storage ───────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=500

# ── CORS ──────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── W&B (optional) ───────────────────────────────────────────────────
WANDB_API_KEY=
WANDB_PROJECT=atmnet-plus-plus

# ── Frontend ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
