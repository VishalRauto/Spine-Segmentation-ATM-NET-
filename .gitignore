# ATM-Net++ .gitignore

# ── Large data files (never commit) ──────────────────────────────────
data/
outputs/cache/
outputs/gpu_run/*.pth
outputs/high_perf_run/*.pth
outputs/training_run/*.pth
*.npz
*.mha
*.nii
*.nii.gz
*.dcm

# ── Python ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
.env

# ── Logs & checkpoints (tracked separately via DVC or releases) ──────
logs/
*.log
tensorboard/
wandb/

# ── Node / Frontend ───────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/.env.local
frontend/out/

# ── Docker ───────────────────────────────────────────────────────────
*.env
.env.local

# ── OS ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Upload dir (runtime) ─────────────────────────────────────────────
uploads/

# ── Keep outputs structure but not binary files ───────────────────────
!outputs/.gitkeep
!checkpoints/.gitkeep
